@page
@model IndexModel
@{
    ViewData["Title"] = "Zalo Chat - SignalR Workspace";
}

<div class="zalo-container">
    <!-- Left Navigation Bar (Zalo Sidebar Icons) -->
    <div class="zalo-navbar">
        <div class="nav-avatar">
            <span class="avatar-circle">AD</span>
            <div class="status-indicator online"></div>
        </div>
        <div class="nav-icons">
            <button class="nav-btn active" title="Tin nhắn">
                <svg viewBox="0 0 24 24" class="svg-icon"><path d="M12 2C6.48 2 2 6.48 2 12c0 2.21.72 4.25 1.94 5.92L3 21l3.15-.99C7.79 20.65 9.8 21 12 21c5.52 0 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"/></svg>
            </button>
            <button class="nav-btn" title="Danh bạ">
                <svg viewBox="0 0 24 24" class="svg-icon"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            </button>
        </div>
        <div class="nav-bottom">
            <button class="nav-btn" id="themeToggle" title="Đổi giao diện">
                <svg viewBox="0 0 24 24" class="svg-icon"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
            </button>
        </div>
    </div>

    <!-- Active Chat Sidebar (Room List) -->
    <div class="zalo-sidebar">
        <div class="sidebar-header">
            <div class="search-container">
                <svg viewBox="0 0 24 24" class="search-icon"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                <input type="text" placeholder="Tìm kiếm nhóm..." id="searchRooms" />
            </div>
            <button class="add-room-btn" title="Tạo nhóm mới" onclick="alert('Tính năng dành cho Member 5 tích hợp SQLite/Modal')">
                <svg viewBox="0 0 24 24" class="svg-icon"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
            </button>
        </div>
        <div class="rooms-list" id="roomsList">
            @foreach (var room in Model.ChatRooms)
            {
                <a class="room-item @(room.Id == Model.ActiveRoomId ? "active" : "")" 
                   href="?roomId=@room.Id" 
                   data-room-id="@room.Id">
                    <div class="room-avatar">@room.Avatar</div>
                    <div class="room-info">
                        <div class="room-name">@room.Name</div>
                        <div class="room-last-msg" id="last-msg-@room.Id">Click để tham gia kênh chat...</div>
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- Main Chat Workspace -->
    <div class="zalo-chat-area">
        <!-- Chat Header -->
        <div class="chat-header">
            <div class="active-room-details">
                <span class="active-room-avatar" id="activeRoomAvatar">💬</span>
                <div>
                    <h2 class="active-room-name" id="activeRoomName">Đang tải...</h2>
                    <p class="connection-status" id="connectionStatus">
                        <span class="status-dot"></span> <span id="statusText">Đang kết nối SignalR...</span>
                    </p>
                </div>
            </div>
            <div class="chat-header-actions">
                <button class="action-btn" title="Tìm tin nhắn">
                    <svg viewBox="0 0 24 24" class="svg-icon"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                </button>
                <button class="action-btn" title="Thông tin cuộc hội thoại" id="toggleDetailsBtn">
                    <svg viewBox="0 0 24 24" class="svg-icon"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                </button>
            </div>
        </div>

        <!-- Connection Lost Banner -->
        <div class="connection-banner hidden" id="connectionBanner">
            Mất kết nối với máy chủ SignalR. Đang thử kết nối lại...
        </div>

        <!-- Chat Feed -->
        <div class="chat-messages-container" id="chatMessages">
            <div class="chat-feed-loader">
                <div class="spinner"></div>
                <p>Đang đồng bộ cuộc hội thoại...</p>
            </div>
        </div>

        <!-- Typing Indicator Area -->
        <div class="typing-indicator-wrapper hidden" id="typingIndicator">
            <span class="typing-text"><strong id="typingUser">User</strong> đang nhập tin nhắn</span>
            <div class="typing-dots">
                <span></span><span></span><span></span>
            </div>
        </div>

        <!-- File Upload Progress Bar Area (For >1GB Uploads) -->
        <div class="upload-progress-container hidden" id="uploadProgressArea">
            <div class="upload-progress-header">
                <span class="upload-file-name" id="uploadFileName">filename.ext</span>
                <span class="upload-file-percent" id="uploadPercent">0%</span>
            </div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill" id="uploadProgressBar" style="width: 0%;"></div>
            </div>
            <div class="upload-progress-footer">
                <span id="uploadSpeed">0 KB/s</span>
                <span id="uploadRemaining">Đang tính toán thời gian...</span>
            </div>
        </div>

        <!-- Selected Attachment Preview Pane -->
        <div class="attachment-preview-pane hidden" id="attachmentPreviewPane">
            <div class="preview-thumbnail-container" id="previewThumbnail">
                <!-- Filled dynamically via createObjectURL -->
            </div>
            <div class="preview-info">
                <div class="preview-filename" id="previewFileName">SelectedFile.zip</div>
                <div class="preview-filesize" id="previewFileSize">0 MB</div>
            </div>
            <button class="cancel-preview-btn" id="cancelPreviewBtn" title="Hủy bỏ">
                <svg viewBox="0 0 24 24" class="svg-icon"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/></svg>
            </button>
        </div>

        <!-- Chat Input Bar -->
        <div class="chat-input-bar">
            <!-- Toolbar -->
            <div class="input-toolbar">
                <!-- Emoji Selector Button -->
                <button class="toolbar-btn" id="emojiBtn" title="Emoji">
                    <svg viewBox="0 0 24 24" class="svg-icon"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 14H11V11H13V16ZM12 9.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
                </button>
                <!-- File Attachment Button -->
                <button class="toolbar-btn" id="attachBtn" title="Gửi File / Ảnh">
                    <svg viewBox="0 0 24 24" class="svg-icon"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-3.31 2.69-6 6-6s6 2.69 6 6v10c0 1.1-.9 2-2 2s-2-.9-2-2V6h-2v9c0 2.21 1.79 4 4 4s4-1.79 4-4V5c0-4.42-3.58-8-8-8s-8 3.58-8 8v12.5c0 3.58 2.92 6.5 6.5 6.5s6.5-2.92 6.5-6.5V6h-2z"/></svg>
                </button>
                <input type="file" id="fileInput" class="hidden" />

                <!-- Set Name Selector -->
                <div class="sender-name-selector">
                    <label for="senderName">Người gửi:</label>
                    <input type="text" id="senderName" value="Thành viên A" placeholder="Tên của bạn" />
                </div>
            </div>

            <!-- Emoji Picker Popover -->
            <div class="emoji-picker hidden" id="emojiPicker">
                <div class="emoji-picker-header">Biểu cảm cảm xúc</div>
                <div class="emoji-picker-grid" id="emojiGrid">
                    <!-- Loaded dynamically via JS -->
                </div>
            </div>

            <!-- Text Area and Send -->
            <div class="input-form">
                <textarea id="messageInput" placeholder="Nhập tin nhắn để gửi đến kênh chat..." rows="1"></textarea>
                <button class="send-message-btn" id="sendBtn" title="Gửi">
                    <svg viewBox="0 0 24 24" class="svg-icon"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Right Drawer (Shared File/Image List - Zalo Style) -->
    <div class="zalo-details-panel hidden" id="detailsPanel">
        <div class="details-header">
            <h3>Thông tin hội thoại</h3>
            <button class="close-details-btn" id="closeDetailsBtn">
                <svg viewBox="0 0 24 24" class="svg-icon"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/></svg>
            </button>
        </div>
        <div class="details-content">
            <div class="details-section">
                <h4>Ảnh đã chia sẻ</h4>
                <div class="shared-images-grid" id="sharedImagesGrid">
                    <!-- Dynamic shared image files -->
                </div>
            </div>
            <div class="details-section">
                <h4>Tài liệu / File đã chia sẻ</h4>
                <div class="shared-files-list" id="sharedFilesList">
                    <!-- Dynamic shared files -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Lightbox Modal for Previews -->
<div class="lightbox-modal hidden" id="lightboxModal">
    <button class="lightbox-close" id="lightboxClose">&times;</button>
    <div class="lightbox-content">
        <img id="lightboxImage" src="" alt="Zoomed View" />
        <div class="lightbox-caption" id="lightboxCaption">image.jpg</div>
    </div>
</div>
